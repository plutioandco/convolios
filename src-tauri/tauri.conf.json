{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Convolios",
  "version": "0.2.0",
  "identifier": "com.plutioandco.convolios",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Convolios",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.unipile.com https://github.com https://*.github.com https://*.githubusercontent.com; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; frame-src https://maps.google.com https://www.google.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Plutio LTD (LV436N5433)"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJBOUYxMEI5MDZBMDA2QUEKUldTcUJxQUd1UkNmdXRjS1FHMkQvMXNNS0M2c2VBSWFBZVZINCsyUnl5VXVvY25HM05uQktWb2UK",
      "endpoints": [
        "https://github.com/plutioandco/convolios/releases/latest/download/latest.json"
      ]
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "convolios"
        ]
      }
    },
    "shell": {
      "open": "^((mailto:\\w+)|(tel:\\w+)|(https?://\\w+)|(x-apple\\.systempreferences:)).+"
    }
  }
}
